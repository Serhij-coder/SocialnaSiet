{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.17.0/.schema/devbox.schema.json",
  "packages": [
    "rustup",
    "postgresql_18",
    "sea-orm-cli",
    "rainfrog@latest"
  ],
  "shell": {
    "init_hook": [
      "rustup default stable 2>/dev/null || true",
      "echo 'Welcome to devbox!' > /dev/null"
    ],
    "scripts": {
      "run": [
        "bash run.sh --run"
      ],
      "migrate": [
        "bash run.sh --migrate"
      ],
      "entities": [
        "bash run.sh --entities"
      ],
      "viewdb": [
        "bash run.sh --viewdb"
      ],
      "services": [
        "devbox services up"
      ],
      "test": [
        "echo \"Error: no test specified\" && exit 1"
      ]
    }
  }
}
